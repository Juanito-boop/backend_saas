  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign Up Owner",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{ownerPassword}}\",\n  \"name\": \"Owner User\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/sign-up/email",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "sign-up",
                "email"
              ]
            },
            "description": "Crea el usuario propietario en Better Auth y deja la cookie de sesion en Postman."
          }
        },
        {
          "name": "Sign In Owner",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{ownerPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/sign-in/email",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "sign-in",
                "email"
              ]
            },
            "description": "Inicia sesion del owner. Postman deberia guardar automaticamente la cookie."
          }
        },
        {
          "name": "Sign Up Member",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{memberEmail}}\",\n  \"password\": \"{{memberPassword}}\",\n  \"name\": \"Member User\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/sign-up/email",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "sign-up",
                "email"
              ]
            },
            "description": "Crea el usuario miembro por Better Auth para que exista en users y tenga credenciales de login."
          }
        },
        {
          "name": "Sign In Member",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{memberEmail}}\",\n  \"password\": \"{{memberPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/sign-in/email",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "sign-in",
                "email"
              ]
            },
            "description": "Inicia sesion del miembro. Si ya habia una cookie del owner, esta request la reemplaza por la del miembro."
          }
        },
        {
          "name": "Get Session",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/get-session",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "get-session"
              ]
            },
            "description": "Verifica que la cookie de sesion este activa antes de probar Teams y Subscriptions."
          }
        }
      ]
    },
    {
      "name": "System",
      "item": [
        {
          "name": "Health Live",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/health/live",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "health",
                "live"
              ]
            },
            "description": "Liveness probe. Solo verifica que el proceso HTTP esta arriba."
          }
        },
        {
          "name": "Health Ready",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/health/ready",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "health",
                "ready"
              ]
            },
            "description": "Readiness probe. Verifica base de datos, auth, cola Redis y acceso real a teams/subscriptions."
          }
        }
      ]
    },
    {
      "name": "Teams",
      "item": [
        {
          "name": "Create Team",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const body = pm.response.json();",
                  "  if (body.id) pm.collectionVariables.set('teamId', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Equipo Demo\",\n  \"plan\": \"starter\",\n  \"urlLimit\": 20,\n  \"userLimit\": 3\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/teams",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "teams"
              ]
            },
            "description": "Crea un equipo y guarda el teamId para el resto de requests. Requiere sesion activa."
          }
        },
        {
          "name": "List My Teams",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/teams",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "teams"
              ]
            }
          }
        },
        {
          "name": "Invite User To Team",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const body = pm.response.json();",
                  "  if (body.user && body.user.id) pm.collectionVariables.set('memberUserId', body.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userEmail\": \"{{memberEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/teams/{{teamId}}/members",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "teams",
                "{{teamId}}",
                "members"
              ]
            },
            "description": "Invita un usuario existente al equipo usando su email."
          }
        },
        {
          "name": "List Team Members",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/teams/{{teamId}}/members",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "teams",
                "{{teamId}}",
                "members"
              ]
            }
          }
        },
        {
          "name": "Promote Member To Admin",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/teams/{{teamId}}/members/{{memberUserId}}/role",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "teams",
                "{{teamId}}",
                "members",
                "{{memberUserId}}",
                "role"
              ]
            }
          }
        },
        {
          "name": "Demote Admin To Member",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"member\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/teams/{{teamId}}/members/{{memberUserId}}/role",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "teams",
                "{{teamId}}",
                "members",
                "{{memberUserId}}",
                "role"
              ]
            }
          }
        },
        {
          "name": "Remove Member",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/teams/{{teamId}}/members/{{memberUserId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "teams",
                "{{teamId}}",
                "members",
                "{{memberUserId}}"
              ]
            }
          }
        }
      ]
    },
